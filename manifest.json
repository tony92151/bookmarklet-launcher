{
  "manifest_version": 3,
  "name": "Bookmarklet Manager",
  "version": "1.0.0",
  "description": "Add and execute your own bookmarklets from the popup (javascript: bookmarklet or raw JS), same effect as bookmarks.",
  "minimum_chrome_version": "135",
  "permissions": ["userScripts", "storage", "activeTab"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bookmarklet Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
